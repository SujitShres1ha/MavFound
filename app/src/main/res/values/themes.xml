<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MavFound" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceContainer">@color/colorCardSurface</item>
        <item name="colorSurfaceContainerHigh">@color/colorCardSurfaceStrong</item>
        <item name="colorOutline">@color/colorStroke</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="materialButtonStyle">@style/Widget.MavFound.Button</item>
        <item name="materialCardViewStyle">@style/Widget.MavFound.Card</item>
    </style>

    <style name="Widget.MavFound.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="Widget.MavFound.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">26dp</item>
        <item name="strokeColor">@color/colorStroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/colorCardSurface</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.MavFound.Button.Destructive" parent="Widget.MavFound.Button">
        <item name="backgroundTint">@color/colorDestructive</item>
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
    </style>

    <style name="Widget.MavFound.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/colorFieldBackground</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/colorPrimary</item>
        <item name="android:textColorHint">@color/colorTextSecondary</item>
    </style>
</resources>
